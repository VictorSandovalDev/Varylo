# Database (Supabase Transaction Pooler)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
# Direct connection (Migrate, etc)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Auth.js
AUTH_SECRET="<generate-with: openssl rand -base64 32>"
AUTH_URL="http://localhost:3000"

# Facebook / Instagram
NEXT_PUBLIC_FACEBOOK_APP_ID=""
META_APP_ID=""
META_APP_SECRET=""
NEXT_PUBLIC_WA_CONFIG_ID=""
WHATSAPP_VERIFY_TOKEN="<generate-a-random-token>"

# OpenAI
OPENAI_API_KEY=""

# SMTP Email
SMTP_HOST=""
SMTP_PORT=465
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM=""

# Security: Allowed origins for server actions (comma-separated, e.g. "app.varylo.com,localhost:3000")
ALLOWED_ORIGINS="localhost:3000"
# Webchat allowed origins (comma-separated, REQUIRED in production)
WEBCHAT_ALLOWED_ORIGINS=""

# Google Calendar OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
